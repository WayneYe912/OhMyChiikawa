{
  "name": "ohmychiikawa",
  "version": "0.0.4",
  "description": "Desktop pet for macOS & Windows. Ships with usagi.",
  "main": "src/main.js",
  "bin": {
    "chiikawa": "chiikawa.js"
  },
  "scripts": {
    "start": "electron .",
    "usagi": "electron . --pet=usagi",
    "chiikawa": "node chiikawa.js",
    "dist": "electron-builder --mac dmg --arm64 --x64",
    "dist:mac": "electron-builder --mac dmg --arm64 --x64",
    "dist:win": "electron-builder --win",
    "dist:win:nsis": "electron-builder --win nsis --x64",
    "dist:win:portable": "electron-builder --win portable --x64"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "usagi",
    "rabbit",
    "offline"
  ],
  "author": "WayneYe",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "build": {
    "appId": "com.ohmychiikawa.desktop",
    "productName": "OhMyChiikawa",
    "directories": {
      "output": "dist",
      "buildResources": "packaging"
    },
    "files": [
      "src/**/*",
      "!src/images/**",
      "chiikawa.js",
      "chiikawa.cmd",
      "chiikawa.ps1",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "packaging/win",
        "to": "packaging/win"
      }
    ],
    "extraMetadata": {
      "main": "src/main.js"
    },
    "mac": {
      "target": "dmg",
      "icon": "packaging/icon.png",
      "category": "public.app-category.entertainment"
    },
    "dmg": {
      "title": "OhMyChiikawa ${version} (${arch})",
      "artifactName": "${productName}-${version}-${arch}.dmg",
      "icon": "packaging/icon.png",
      "window": {
        "width": 540,
        "height": 480
      },
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 140,
          "y": 360,
          "type": "file",
          "path": "packaging/dmg/install-cli.command"
        },
        {
          "x": 400,
          "y": 360,
          "type": "file",
          "path": "packaging/dmg/READ-ME-FIRST.txt"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "packaging/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OhMyChiikawa",
      "artifactName": "${productName}-${version}-win-x64.${ext}",
      "installerIcon": "packaging/icon.ico",
      "uninstallerIcon": "packaging/icon.ico",
      "installerHeaderIcon": "packaging/icon.ico",
      "include": "packaging/nsis/install-cli.nsh"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-x64.${ext}"
    }
  },
  "devDependencies": {
    "electron": ">=26.0.0",
    "electron-builder": "^26.15.3"
  }
}
